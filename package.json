{
  "name": "hammoud-household",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "start": "cd server && node index.js"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
